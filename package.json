{
  "name": "@hasna/emails",
  "version": "0.5.12",
  "description": "Email management CLI + MCP server + dashboard for Resend and AWS SES",
  "type": "module",
  "bin": {
    "emails": "dist/cli/index.js",
    "emails-mcp": "dist/mcp/index.js",
    "emails-serve": "dist/server/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pg-migrations": {
      "import": "./dist/db/pg-migrations.js"
    },
    "./dist/db/pg-migrations.js": {
      "import": "./dist/db/pg-migrations.js"
    }
  },
  "files": [
    "dist",
    "dashboard/dist",
    "dashboard/index.html",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/cli/index.tsx --outdir dist/cli --target bun --external ink --external react --external chalk --external @modelcontextprotocol/sdk && bun build src/mcp/index.ts --outdir dist/mcp --target bun --external @modelcontextprotocol/sdk && bun build src/server/index.ts --outdir dist/server --target bun && bun build src/index.ts --outdir dist --target bun && tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "dev:cli": "bun run src/cli/index.tsx",
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:serve": "bun run src/server/index.ts",
    "postinstall": "mkdir -p $HOME/.hasna/emails 2>/dev/null || true"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": "Andrei Hasna <andrei@hasna.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1020.0",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/client-ses": "^3.1020.0",
    "@aws-sdk/client-sesv2": "^3.0.0",
    "@hasna/cloud": "^0.1.24",
    "@hasna/connect-cloudflare": "/home/hasna/workspace/hasna/opensource/opensourcedev/open-connectors/connectors/connect-cloudflare",
    "@hasna/connectors": "^1.3.3",
    "@hasna/domains": "^0.0.3",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "googleapis": "^171.4.0",
    "ink": "^5.2.0",
    "mailparser": "^3.9.6",
    "react": "^18.3.1",
    "resend": "^4.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/mailparser": "^3.4.6",
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3"
  }
}